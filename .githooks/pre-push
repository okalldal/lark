#!/usr/bin/env bash
#
# Pre-push gate: runs the local CI gate (lark-rs/scripts/check.sh) and aborts
# the push if any check fails. Enable once per clone with:
#
#   git config core.hooksPath .githooks
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GATE="$REPO_ROOT/lark-rs/scripts/check.sh"

if [ ! -x "$GATE" ]; then
  echo "pre-push: gate script not found or not executable: $GATE" >&2
  exit 1
fi

echo "pre-push: running local CI gate before push…"
exec "$GATE"
