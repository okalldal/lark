{
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(rustfmt:*)",
      "Bash(python3 lark-rs/tools/generate_oracles.py*)",
      "Bash(python3 tools/generate_oracles.py*)",
      "Bash(python3 lark-rs/tools/extract_lark_compliance.py*)",
      "Bash(python3 tools/extract_lark_compliance.py*)",
      "Bash(python3 lark-rs/tools/generate_wild_oracles.py*)",
      "Bash(python3 tools/generate_wild_oracles.py*)",
      "Bash(python3 -c:*)",
      "Bash(lark-rs/scripts/check-fast.sh)",
      "Bash(./scripts/check-fast.sh)",
      "Bash(scripts/check-fast.sh)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git submodule update*)",
      "Bash(git config core.hooksPath .githooks)"
    ],
    "deny": [
      "Edit(lark-rs/tests/fixtures/oracles/**)",
      "Write(lark-rs/tests/fixtures/oracles/**)",
      "Edit(lark-rs/tests/standalone/*.rs)",
      "Write(lark-rs/tests/standalone/*.rs)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 600
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.rs) rustfmt --edition 2021 \"$f\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ]
  }
}
