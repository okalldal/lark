  {
    "name": "trailing_neg_lookahead",
    "grammar": "\nstart: A B\nA: /a+(?!b)/\nB: /[ab]+/\n",
    "g_regex_flags": [],
    "cases": [
      {
        "input": "aaab",
        "should_pass": true,
        "ok": true,
        "tree": {
          "type": "tree",
          "data": "start",
          "children": [
            {
              "type": "token",
              "token_type": "A",
              "value": "aa"
            },
            {
              "type": "token",
              "token_type": "B",
              "value": "ab"
            }
          ]
        },
        "error": null
      },
      {
        "input": "aab",
        "should_pass": true,
        "ok": true,
        "tree": {
          "type": "tree",
          "data": "start",
          "children": [
            {
              "type": "token",
              "token_type": "A",
              "value": "a"
            },
            {
              "type": "token",
              "token_type": "B",
              "value": "ab"
            }
          ]
        },
        "error": null
      },
      {
        "input": "ab",
        "should_pass": false,
        "ok": false,
        "tree": null,
        "error": "Unexpected token Token('B', 'ab') at line 1, column 1.\nExpected one of: \n\t* A\nPrevious tokens: [None]\n"
      },
      {
        "input": "aaa",
        "should_pass": false,
        "ok": false,
        "tree": null,
        "error": "Unexpected token Token('$END', '') at line 1, column 1.\nExpected one of: \n\t* B\n"
      }
    ]
