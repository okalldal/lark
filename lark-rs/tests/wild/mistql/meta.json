{
  "name": "mistql",
  "description": "MistQL query language for JSON-like structures. The only Earley + dynamic-lexer entry in the bank.",
  "source": {
    "repo": "https://github.com/evinism/mistql",
    "ref": "HEAD",
    "commit": "e1aa6ecef18d362510497e89a936c4d8534a6fd1",
    "license": "MIT",
    "grammar_files": {
      "grammar/grammar.lark": "py/mistql/grammar.lark"
    }
  },
  "entry_grammar": "grammar/grammar.lark",
  "lark_options": {
    "parser": "earley",
    "lexer": "dynamic",
    "start": "start",
    "maybe_placeholders": true,
    "propagate_positions": false,
    "keep_all_tokens": false,
    "regex_module": false,
    "postlex": null
  },
