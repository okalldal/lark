{
  "name": "synapse_storm",
  "description": "Storm query language from the Synapse intelligence-analysis platform. A very large LALR grammar; upstream loads it with regex=True (the `regex` module) and start=\"query\".",
  "source": {
    "repo": "https://github.com/vertexproject/synapse",
    "ref": "HEAD",
    "commit": "452fb90f166c287fed5bee5e38c32b6e94fdd910",
    "license": "Apache-2.0",
    "grammar_files": {
      "grammar/storm.lark": "synapse/data/lark/storm.lark"
    }
  },
  "entry_grammar": "grammar/storm.lark",
  "lark_options": {
    "parser": "lalr",
    "lexer": "contextual",
    "start": "query",
    "maybe_placeholders": false,
    "propagate_positions": true,
    "keep_all_tokens": false,
    "regex_module": true,
    "postlex": null
  },
