{
  "name": "cel",
  "description": "Google Common Expression Language (CEL) grammar from cel-python. Upstream also passes lexer_callbacks={\"IDENT\": ...} (a reserved-word retype); the bank drops it — the oracle and the replay both parse without it.",
  "source": {
    "repo": "https://github.com/cloud-custodian/cel-python",
    "ref": "HEAD",
    "commit": "cbe3d5d1a19ee947b85e0533bc78714631d935cb",
    "license": "Apache-2.0",
    "grammar_files": {
      "grammar/cel.lark": "src/celpy/cel.lark"
    }
  },
  "entry_grammar": "grammar/cel.lark",
  "lark_options": {
    "parser": "lalr",
    "lexer": "contextual",
    "start": "expr",
    "maybe_placeholders": false,
    "propagate_positions": true,
    "keep_all_tokens": false,
    "regex_module": false,
    "postlex": null,
    "g_regex_flags": "m"
  },
  "inputs": {
